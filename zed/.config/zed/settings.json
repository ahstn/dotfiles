// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "completions": {
    "lsp_fetch_timeout_ms": 200,
  },
  "active_pane_modifiers": {
    "border_size": 1.0,
  },
  "centered_layout": {
    "right_padding": 0.2,
    "left_padding": 0.2,
  },
  "bottom_dock_layout": "full",
  "tabs": {
    "show_diagnostics": "errors",
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
  },
  "title_bar": {
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "pi-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
    "button": true,
    "diagnostic_badges": true,
  },
  "outline_panel": {
    "dock": "left",
    "button": false,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "git_panel": {
    "folder_icons": true,
    "file_icons": false,
    "status_style": "icon",
    "dock": "right",
    "button": true,
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "left",
    "button": true,
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "openrouter",
      "model": "openai/gpt-5",
    },
  },

  //
  "ssh_connections": [
    {
      "host": "192.168.1.11",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ahstn/services"],
        },
      ],
    },
    {
      "host": "192.168.1.135",
      "username": "ahstn",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ahstn/git"],
        },
      ],
    },
  ],
  "edit_predictions": {
    "provider": "copilot",
  },
  "icon_theme": "Catppuccin Frappé",

  // User Interface
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Frappé",
  },
  "max_tabs": 4,
  "use_system_window_tabs": true,
  "cli_default_open_behavior": "existing_window",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },

  // Fonts
  "buffer_font_family": "JuliaMono",
  "buffer_font_fallbacks": ["Hack", ".ZedMono"],
  "ui_font_family": ".ZedSans",
  "ui_font_size": 15.0,
  "buffer_font_size": 14.0,

  "which_key": {
    "delay_ms": 300,
    "enabled": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "padding": 6,
      "min_column": 50,
      "max_severity": "error",
    },
  },

  // Language Specifics
  "languages": {
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true,
      },
      "language_servers": [
        "ruff",
        "ty",
        "!pyrefly",
        "!basedpyright",
        "!pyright",
      ],
      "format_on_save": "on",
    },
  },
}
