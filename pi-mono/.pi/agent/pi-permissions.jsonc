{
  "defaultPolicy": {
    "tools": "allow",
    "bash": "ask",
    "mcp": "ask",
    "skills": "allow",
    "special": "ask",
  },
  "tools": {
    "read": "allow",
    "write": "allow",
    "grep": "allow",
    "exa_websearch": "allow",
  },
  "special": {
    "doom_loop": "deny",
    "external_directory": "ask",
  },
  "bash": {
    // general
    "rm -rf*": "deny",
    "ls*": "allow",
    "tail*": "allow",
    "head*": "allow",
    "grep*": "allow",
    "rg*": "allow",
    "find*": "allow",
    "fd*": "allow",
    "which*": "allow",
    "mkdir*": "allow",
    "pwd": "allow",
    "eval \"$(/Users/ahstn/.local/bin/mise activate zsh)\"": "allow",
    // devops
    "helm lint*": "allow",
    "helm template*": "allow",
    "helm repo*": "allow",
    "podman*": "allow",
    "docker*": "allow",
    "buildctl*": "allow",
    // git
    "git status*": "allow",
    "git diff*": "allow",
    "git rev-parse*": "allow",
    "git add*": "ask", // catch intentional untracked files
    "git commit*": "allow",
    "git log*": "allow",
    "git branch*": "allow",
    "gh label *": "allow",
    "gh pr *": "allow",
    "gh pr create*": "ask",
    // mise & ptchfork
    "mise activate*": "allow",
    "mise use*": "allow",
    "mise run*": "allow",
    "mise ls-remote*": "allow",
    "pitchfork *": "allow",
    // typescript
    "npm info*": "allow",
    "npm ls*": "allow",
    "npm view*": "allow",
    "npm run *": "allow", // allow project commands but block random npm calls
    "npx oxlint*": "allow",
    "npx oxfmt*": "allow",
    "npx jest*": "allow",
    "npx vitest*": "allow",
    "npx turbo*": "allow",
    "npx tsx*": "allow",
    "npx *": "ask",
    "bun run *": "allow",
    "bun add *": "allow",
    "bun install *": "allow",
    // rust
    "cargo build*": "allow",
    "cargo clean*": "allow",
    "cargo clippy*": "allow",
    "cargo doc*": "allow",
    "cargo search*": "allow",
    "cargo info*": "allow",
    "cargo fetch*": "allow",
    "cargo fix*": "allow",
    "cargo test*": "allow",
    "cargo package*": "allow",
    "cargo add*": "allow",
    "cargo tree*": "allow",
    "cargo init*": "allow",
    "cargo new*": "allow",
    // python
    "uv run pytest*": "allow",
    "uv run ruff*": "allow",
    "uv run ty*": "allow",
    "maturin build*": "allow",
  },
}
