# Entity-level semantic merge driver for Git
# https://github.com/Ataraxy-Labs/weave
brew 'weave'

# Menu bar wrapper for `caffeinate`
# https://github.com/newmarcel/KeepingYouAwake
cask 'keepingyouawake'

# snapshots tmux sessions with runed processes
# https://github.com/alchemmist/lazy-tmux
tap 'alchemmist/tap/lazy-tmux'

# replace macos utilities with gnu coreutils
brew 'coreutils'

# remaining self explanatory packages
brew 'fd'
brew 'fzf'
brew 'git'
brew 'stow'

# vscode extensions
vscode "astral-sh.ty"
vscode "catppuccin.catppuccin-vsc"
vscode "catppuccin.catppuccin-vsc-icons"
vscode "charliermarsh.ruff"